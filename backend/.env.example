# ─────────────────────────────────────────────
#  Environment Variables — Mobile Covers Chatbot
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Google Gemini API Key (get free at https://aistudio.google.com)
GEMINI_API_KEY=AIzaSyA_OS6UnIzvIfxGn3h56XUaAN7SofMbOtc

# Your Shopify store URL (just the subdomain, no https://)
# Example: my-store.myshopify.com
SHOPIFY_STORE_URL=classycase.store

# Display name of your store (used in chatbot responses)
STORE_NAME=ClassyCase

# CORS: comma-separated list of allowed origins
# For development use * — in production, set to your Shopify domain
# Example: https://my-store.myshopify.com,https://www.mysite.com
ALLOWED_ORIGINS=*

# Auto-sync interval in hours (how often to re-fetch products from Shopify)
SYNC_INTERVAL_HOURS=6

# Port to run the backend server on (default: 8000)
PORT=8000
